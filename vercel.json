{
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://your-auth-wrapper.railway.app/api/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://your-flowdesk-backend.onrender.com/api/:path*"
    },
    {
      "source": "/app/:path*",
      "destination": "https://your-flowdesk-backend.onrender.com/app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
